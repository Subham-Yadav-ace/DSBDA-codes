-- =========================================
-- STEP 1 : Leave Safe Mode (Run in terminal)
-- =========================================

hdfs dfsadmin -safemode leave
sudo -u hdfs hadoop dfsadmin -safemode leave


-- =========================================
-- STEP 2 : Start Hive
-- =========================================

hive


-- =========================================
-- STEP 3 : Create Database
-- =========================================

CREATE DATABASE flightdb;


-- =========================================
-- STEP 4 : Use Database
-- =========================================

USE flightdb;


-- =========================================
-- STEP 5 : Show Databases
-- =========================================

SHOW DATABASES;


-- =========================================
-- STEP 6 : Create Flight Table
-- =========================================

CREATE TABLE flight (
    year INT,
    month INT,
    day INT,
    flight_no STRING,
    customer_id INT,
    origin STRING,
    dest STRING,
    dep_delay INT
)
ROW FORMAT DELIMITED
FIELDS TERMINATED BY ','
STORED AS TEXTFILE;


-- =========================================
-- STEP 7 : Describe Flight Table
-- =========================================

DESCRIBE flight;


-- =========================================
-- STEP 8 : Insert Data into Flight Table
-- =========================================

INSERT INTO TABLE flight VALUES
(2008,5,5,'AA123',101,'JFK','LAX',15),
(2008,5,5,'DL456',102,'SFO','ORD',-5),
(2008,5,6,'UA789',103,'SEA','DEN',0),
(2008,5,6,'WN101',104,'DAL','HOU',120);


-- =========================================
-- STEP 9 : View Flight Table Data
-- =========================================

SELECT * FROM flight;


-- =========================================
-- STEP 10 : Alter Flight Table
-- =========================================

ALTER TABLE flight ADD COLUMNS (airline STRING);


-- =========================================
-- STEP 11 : Check Updated Table Structure
-- =========================================

DESCRIBE flight;


