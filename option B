🔹 STEP 6: Create Flight Table

CREATE TABLE flight (
    year INT,
    month INT,
    day INT,
    flight_no STRING,
    customer_id INT,
    origin STRING,
    dest STRING,
    dep_delay INT
)
ROW FORMAT DELIMITED
FIELDS TERMINATED BY ','
STORED AS TEXTFILE;


🔹 Check Flight Table
DESCRIBE flight;


