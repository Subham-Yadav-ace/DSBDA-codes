🔥 STEP 13: Perform JOIN on Flight and Customer Table

SELECT flight.flight_no,
       customer.customer_name,
       customer.city,
       flight.dest,
       flight.dep_delay

FROM flight
JOIN customer
ON flight.customer_id = customer.customer_id;


🔥 STEP 14: Create Index on Flight Table

CREATE INDEX flight_index
ON TABLE flight (flight_no)
AS 'COMPACT'
WITH DEFERRED REBUILD;

🔹 Build Index
ALTER INDEX flight_index ON flight REBUILD;



🔥 STEP 15: Find Average Departure Delay Per Day

SELECT day,AVG(dep_delay) AS avg_delay
FROM flight
WHERE year = 2026
GROUP BY day;
