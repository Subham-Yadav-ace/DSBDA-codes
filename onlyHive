-- =========================================
-- STEP 15 : Create EXTERNAL Customer Table
-- =========================================

CREATE EXTERNAL TABLE customer (
    customer_id INT,
    customer_name STRING,
    city STRING
)
ROW FORMAT DELIMITED
FIELDS TERMINATED BY ','
STORED AS TEXTFILE
LOCATION '/home/cloudera/Desktop/customer_data';


-- =========================================
-- STEP 16 : View Customer Table Data
-- =========================================

SELECT * FROM customer;


-- =========================================
-- STEP 17 : Insert New Record into Customer
-- =========================================

INSERT INTO TABLE customer VALUES
(105,'Karan','Chennai');


-- =========================================
-- STEP 18 : View Updated Customer Table
-- =========================================

SELECT * FROM customer;


-- =========================================
-- STEP 19 : Join Flight and Customer Tables
-- =========================================

SELECT flight.flight_no,
       customer.customer_name,
       customer.city,
       flight.dest,
       flight.dep_delay

FROM flight
JOIN customer
ON flight.customer_id = customer.customer_id;


-- =========================================
-- STEP 20 : Create Index on Flight Table
-- =========================================

CREATE INDEX flight_index
ON TABLE flight (flight_no)
AS 'org.apache.hadoop.hive.ql.index.compact.CompactIndexHandler'
WITH DEFERRED REBUILD;


-- =========================================
-- STEP 21 : Rebuild Index
-- =========================================

ALTER INDEX flight_index ON flight REBUILD;


-- =========================================
-- STEP 22 : Show Index
-- =========================================

SHOW INDEX ON flight;


-- =========================================
-- STEP 23 : Find Average Departure Delay
-- =========================================

SELECT day,
       AVG(dep_delay) AS avg_delay

FROM flight

WHERE year = 2008

GROUP BY day;
