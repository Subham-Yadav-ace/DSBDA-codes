   "source": [
    "#!/usr/bin/env python\n",
    "import sys\n",
    "\n",
    "for line in sys.stdin:\n",
    "    # Split line into words and emit each word with a count of 1\n",
    "    for word in line.split():\n",
    "        print '{0}\\t{1}'.format(word, 1)"
   ]
  }
